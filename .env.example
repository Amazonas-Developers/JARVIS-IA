# Plantilla de configuración. Copia este archivo como `.env` y ajusta los valores.
# IMPORTANTE:
# - Tras cambiar el .env hay que reiniciar `npm run dev` (se inyecta en build).
# - Estos valores actúan como POR DEFECTO: lo que el usuario edite en la UI
#   (URL, key de Tavily) se guarda en localStorage y tiene prioridad.
# - Al ser una app 100% cliente, estos valores acaban en el bundle JS.
#   No pongas aquí secretos que no puedan ser públicos para quien use la app.

# URL del servidor LM Studio (con el servidor local activado)
VITE_LM_STUDIO_URL=http://192.168.1.50:1234

# Temperatura por defecto del modelo (0 a 2)
VITE_TEMPERATURE=0.7

# Máximo de tokens por defecto de cada respuesta
VITE_MAX_TOKENS=1024

# API key de Tavily para la búsqueda web (https://tavily.com — 1000 búsquedas/mes gratis)
VITE_TAVILY_API_KEY=

# URL del backend con autenticación por sesión (express-session), p. ej. http://localhost:3000
# La usa la instancia de axios de src/libs/http.ts (withCredentials: true).
# Si se deja vacía, las peticiones son relativas al origen de la app (o al proxy de Vite).
VITE_API_URL=
